@model IEnviormentRepository
@{
    Layout = "CordinatorLayout";
}

<div id="content">
    <h2>Ärenden</h2>

        <p class="info">Du är inloggad som Samordnare</p>

        <!-- Filter form -->
        <form method="post" asp-controller="Cordinator" asp-action="StartCordinator">
        <table id="managerForm">
            <tr>
                <td class="label">Välj status:</td>
                <td class="label">Välj avdelning:</td>
                <td>&nbsp;</td>
                <td class="label">Ärendenummer:</td>
                <td>&nbsp;</td>
            </tr>
            <tr>
                <td>
                    <select name="StatusChoice">
                        <option selected="selected">Välj alla</option>
                        @foreach (var status in Model.ErrandStatuses)  
                        {
                            <option value="@status.StatusName">@status.StatusName</option>
                        }
                    </select>
                </td>
                <td>
                    <select name="DepartmentChoice">
                        <option selected="selected">Välj alla</option>
                        @foreach (var department in Model.Departments.Skip(1))
                        {
                            <option value="@department.DepartmentName">@department.DepartmentName</option>
                        }
                    </select>
                </td>
                
            <td><input class="button" type="submit" value="Hämta lista" /></td>
            <td><input name="casenumber" /></td>
            <td><input class="button" type="submit" value="Sök" /></td>
            </tr>
        </table>
        </form>
     

        

    
        <table>
        
            <tr>
                <th>Ärende anmält</th>
                <th>Ärendenummer</th>
                <th>Miljöbrott</th>
                <th>Status</th>
                <th>Avdelning</th>
                <th>Handläggare</th>
            </tr>





        @foreach (MyErrand errand in @ViewBag.ErrandList)
                {
                    <tr>
                        <td>@errand.DateOfObservation.ToShortDateString()</td>
                        <td>
                    <a asp-controller="Cordinator" asp-action="CrimeCordinator" asp-route-errandId="@errand.ErrandId">@errand.RefNumber</a>

                        </td>
                        <td>@errand.TypeOfCrime</td>
                        <td>@errand.StatusName</td>
                        <td>@errand.DepartmentName</td>
                        <td>@errand.EmployeeName</td>
                    </tr>
                }
            
           
        </table>
    
</div>
