@model EnviroooProject.Models.Errand

@{
	Layout = "CitizenLayout";
}

<div id="content">
	<section id="mainColumn">
		<h2>Välkommen att fylla i din anmälan av miljöbrott</h2>
		<p class="info">I Småstad är inga brott för små för att anmälas</p>

		<p>Fyll i formuläret nedan, alla rutor markerade med stjärna (*) måste fyllas i.</p>

		<form method="post" asp-controller="citizen" asp-action="validate">
			<p>
				<input type="hidden" name="isSubmitted" value="true" />
			</p>
			<p>
				<label asp-for="Place"></label><br />
				<input asp-for="Place" /> *
				<span asp-validation-for="Place"></span>
			</p>
			<p>
				<label asp-for="TypeOfCrime"></label><br />
				<input asp-for="TypeOfCrime" /> *
				<span asp-validation-for="TypeOfCrime"></span>
			</p>
			<p>
				<label asp-for="DateOfObservation"></label><br />
				<input asp-for="DateOfObservation" />*
				<span asp-validation-for="DateOfObservation"></span>
			</p>
			<p>
				<label asp-for="InformerName"></label><br />
				<input asp-for="InformerName"/> *
				<span asp-validation-for="InformerName"></span>
			</p>
			<p>
				<label asp-for="InformerPhone"></label><br />
				<input asp-for="InformerPhone" /> *
				<span asp-validation-for="InformerPhone"></span>
			</p>
			<p>
				<label asp-for="Observation"></label><br />
				<textarea asp-for="Observation" rows="5" cols="16"></textarea>
			</p>
			<p>
				<input class="button" type="submit" value="Skicka in" />
			</p>
		</form>
	</section><!-- End left -->

	<aside id="sideColumn">
		<img src="images/pic_1.jpg" height="162" alt="Ett barn blåser på en maskros" />
		<img src="images/pic_2.jpg" height="162" alt="Åkrar utanför Småstad med hus och kyrkan i bakgrunden" />
		<img src="images/pic_3.jpg" height="162" alt="Flygbild över Småstads villaområde" />
		<img src="images/pic_4.jpg" height="162" alt="En kvinna vänder ansiktet mot solen och vinden rör om hennes hår" />
		<img src="images/pic_5.jpg" height="162" alt="En åker vid första frosten" />
		<img src="images/pic_6.jpg" height="162" alt="Händer som håller i jord och en liten planta" />
		<img src="images/pic_7.jpg" height="162" alt="Barn liggandes på gräsmatta" />
		<img src="images/pic_8.jpg" height="162" alt="Närbild av en fotboll" />
	</aside><!-- End right -->
